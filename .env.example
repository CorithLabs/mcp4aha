# ============================================================
# Aha MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Ports -----
# Port for the admin portal (default: 3000)
PORTAL_PORT=3000

# Port for the MCP SSE server that Claude Desktop connects to (default: 3001)
MCP_PORT=3001

# ----- Pre-seed config (optional) -----
# You can set these here to skip the portal setup step.
# If set, they take precedence over the database values.

# Your Aha company subdomain (e.g. "mycompany" from mycompany.aha.io)
AHA_COMPANY=

# A pre-generated MCP auth token (leave blank to generate via portal)
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# ----- Notes -----
# AHA_TOKEN (user's personal Aha API key) is NOT set here.
# Each Claude Desktop user passes their own API key per-request via
# the X-Aha-Api-Key header in their claude_desktop_config.json.
